*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.venv/
venv/
.mypy_cache/
.ruff_cache/

# uv
uv.lock

# Data & large artifacts (regenerated by scripts; do not commit)
data/*
!data/.gitkeep
data/LibriSpeech/
data/VCTK/
*.wav
*.flac
*.pt
*.ckpt
*.onnx

# Results: keep small JSON/CSV summaries + figures, ignore bulky dumps
results/**/*.npz
results/**/*.npy
results/**/raw/

# LaTeX build cruft
paper/*.aux
paper/*.log
paper/*.out
paper/*.blg
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls
paper/*.toc

# OS
.DS_Store
Thumbs.db
